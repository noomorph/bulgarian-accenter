root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

# The front-coded dictionary. Every byte is load-bearing; do not let an editor touch it.
[data/stress-dict.txt]
trim_trailing_whitespace = false
insert_final_newline = false
