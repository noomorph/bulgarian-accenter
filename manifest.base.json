{
  "manifest_version": 3,
  "name": "Bulgarian Accenter",
  "description": "Marks stressed vowels in Bulgarian text on any page, offline, from a built-in dictionary.",
  "homepage_url": "https://github.com/noomorph/bulgarian-accenter",
  "action": {
    "default_title": "Bulgarian Accenter",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/dict.js", "src/accent.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
